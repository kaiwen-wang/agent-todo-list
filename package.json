{
  "name": "agent-todo-list",
  "description": "Local-first, CRDT-backed todo/project management for AI coding agents",
  "type": "module",
  "private": true,
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaiwen-wang/agent-todo-list.git"
  },
  "workspaces": ["src/web"],
  "bin": {
    "agt": "src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/server/index.ts & cd src/web && bunx vite",
    "build": "bun run --cwd src/web build",
    "serve": "bun src/server/index.ts",
    "agt": "bun src/cli/index.ts",
    "lint": "oxlint src/lib src/cli src/server --fix",
    "format": "oxfmt src/lib src/cli src/server",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.4",
    "commander": "^14.0.0",
    "chalk": "^5.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "lefthook": "^2.1.3",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.53.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
